<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenUtau.App.Views.VocoderCreditDialog"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/pmou.png"
        Title="{StaticResource dialogs.potluckvocoder.caption}"
        Width="440" SizeToContent="Height" CanResize="False">
  <StackPanel Margin="20,16,20,16" Spacing="12">
    <TextBlock Text="{StaticResource dialogs.potluckvocoder.message}" TextWrapping="Wrap" />
    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
      <CheckBox Name="DontShowAgain" Grid.Column="0" VerticalAlignment="Center" />
      <TextBlock Grid.Column="1" Text="{StaticResource dialogs.potluckvocoder.dontshow}"
                 VerticalAlignment="Center" Margin="4,0,0,0" />
      <Button Grid.Column="2" Content="{StaticResource button.ok}"
              Click="OnOk" MinWidth="80" HorizontalContentAlignment="Center" />
    </Grid>
  </StackPanel>
</Window>
