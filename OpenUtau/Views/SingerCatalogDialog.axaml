<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OpenUtau.App.ViewModels"
        mc:Ignorable="d"
        x:Class="OpenUtau.App.Views.SingerCatalogDialog"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource singercatalog.caption}" Width="540" Height="600"
        WindowStartupLocation="CenterScreen">
  <Design.DataContext>
    <vm:SingerCatalogViewModel/>
  </Design.DataContext>
  <Window.Resources>
    <DataTemplate x:Key="SingerRow">
      <Border Padding="8,6" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource SystemControlHighlightBaseMediumLowBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <Border Grid.Column="0" Width="30" Height="30" Margin="0,0,10,0" CornerRadius="4"
                  ClipToBounds="True" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Image Source="{Binding Image}" Stretch="UniformToFill" IsVisible="{Binding HasImage}"/>
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Author}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="{Binding VersionDisplay}" FontSize="11" Opacity="0.6"
                       VerticalAlignment="Center" IsVisible="{Binding !IsExternal}"/>
            <Button Content="{Binding ActionLabel}" IsEnabled="{Binding CanAction}"
                    IsVisible="{Binding !IsExternal}" Click="OnInstallClick" MinWidth="80"/>
            <Button Content="{DynamicResource singercatalog.action.website}"
                    IsVisible="{Binding IsExternal}" Click="OnOpenWebClick" MinWidth="80"/>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>
  <Grid Margin="10" RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0">
      <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
          <TextBlock Text="{DynamicResource singercatalog.category.builtin}" FontSize="14" FontWeight="Bold"/>
          <TextBlock Text="{Binding BuiltInSingers.Count, StringFormat=' ({0})'}" FontSize="14" Opacity="0.6"/>
        </StackPanel>
        <ItemsControl ItemsSource="{Binding BuiltInSingers}" ItemTemplate="{StaticResource SingerRow}"/>
        <StackPanel Orientation="Horizontal" Margin="0,16,0,2">
          <TextBlock Text="{DynamicResource singercatalog.category.public}" FontSize="14" FontWeight="Bold"/>
          <TextBlock Text="{Binding PublicSingers.Count, StringFormat=' ({0})'}" FontSize="14" Opacity="0.6"/>
        </StackPanel>
        <ItemsControl ItemsSource="{Binding PublicSingers}" ItemTemplate="{StaticResource SingerRow}"/>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center" TextWrapping="Wrap"/>
      <Button Grid.Column="1" Content="{DynamicResource singercatalog.refresh}" Command="{Binding RefreshCommand}"/>
    </Grid>
  </Grid>
</Window>
