<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OpenUtau.App.ViewModels"
        mc:Ignorable="d"
        x:Class="OpenUtau.App.Views.SingerCatalogDialog"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource singercatalog.caption}" Width="620" Height="680"
        WindowStartupLocation="CenterScreen">
  <Design.DataContext>
    <vm:SingerCatalogViewModel/>
  </Design.DataContext>
  <Window.Resources>
    <DataTemplate x:Key="SingerCard">
      <Border Margin="0,0,0,8" Padding="10" CornerRadius="6"
              Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              BorderBrush="{DynamicResource SystemControlHighlightBaseMediumHighBrush}"
              BorderThickness="1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Width="72" Height="72" Margin="0,0,12,0"
                  ClipToBounds="True" CornerRadius="4"
                  Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Image Source="{Binding Image}" Stretch="UniformToFill" IsVisible="{Binding HasImage}"/>
          </Border>
          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"/>
            <TextBlock Text="{Binding Author}" Opacity="0.8" FontSize="12"/>
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxLines="3"
                       Opacity="0.9" FontSize="12"/>
            <TextBlock Text="{Binding VersionDisplay}" Opacity="0.6" FontSize="11"
                       IsVisible="{Binding !IsExternal}"/>
          </StackPanel>
          <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="6">
            <Button MinWidth="90" HorizontalContentAlignment="Center"
                    Content="{Binding ActionLabel}" IsEnabled="{Binding CanAction}"
                    IsVisible="{Binding !IsExternal}" Click="OnInstallClick"/>
            <Button MinWidth="90" HorizontalContentAlignment="Center"
                    Content="{DynamicResource singercatalog.action.website}"
                    IsVisible="{Binding IsExternal}" Click="OnOpenWebClick"/>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>
  <Grid Margin="10" RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0">
      <StackPanel>
        <TextBlock Text="{DynamicResource singercatalog.category.builtin}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
        <ItemsControl ItemsSource="{Binding BuiltInSingers}" ItemTemplate="{StaticResource SingerCard}"/>
        <TextBlock Text="{DynamicResource singercatalog.category.public}"
                   FontSize="18" FontWeight="Bold" Margin="0,12,0,8"/>
        <ItemsControl ItemsSource="{Binding PublicSingers}" ItemTemplate="{StaticResource SingerCard}"/>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center" TextWrapping="Wrap"/>
      <Button Grid.Column="1" Content="{DynamicResource singercatalog.refresh}"
              Command="{Binding RefreshCommand}"/>
    </Grid>
  </Grid>
</Window>
